-	/* Non-ECT altered to something or something became non-ECT */
-	if (snt == INET_ECN_NOT_ECT || rcv == INET_ECN_NOT_ECT)
-		return false;
-	/* CE -> ECT(0/1)? */
-	if (snt == INET_ECN_CE)
-		return false;
-	return true;
-}
