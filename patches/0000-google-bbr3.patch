-	if (tp->ecn_flags & TCP_ECN_MODE_ACCECN) {
-		TCP_SKB_CB(skb)->tcp_flags &= ~TCPHDR_ACE;
-		TCP_SKB_CB(skb)->tcp_flags |=
-			tcp_accecn_reflector_flags(tp->syn_ect_rcv);
