-	case INET_ECN_NOT_ECT:
-		return 0;	/* AccECN does not send counts of NOT_ECT */
-	case INET_ECN_ECT_1:
-		return 1;
-	case INET_ECN_CE:
-		return 2;
-	case INET_ECN_ECT_0:
-		return 3;
-	}
-	return 0;
-}
