-		if (len > 0) {
-			u8 minlen = tcp_ecnfield_to_accecn_optfield(ecnfield);
-			u32 oldbytes = tp->received_ecn_bytes[ecnfield - 1];
-			u32 bytes_mask = GENMASK_U32(31, 22);
