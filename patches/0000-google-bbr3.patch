-	case INET_ECN_NOT_ECT:
-		return 0;	/* AccECN does not send counts of NOT_ECT */
-	case INET_ECN_ECT_1:
-		return TCP_ACCECN_E1B_INIT_OFFSET;
-	case INET_ECN_CE:
-		return TCP_ACCECN_CEB_INIT_OFFSET;
-	case INET_ECN_ECT_0:
-		return TCP_ACCECN_E0B_INIT_OFFSET;
