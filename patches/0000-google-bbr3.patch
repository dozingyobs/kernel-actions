-		u8 saw_opt = tcp_accecn_option_init(skb, tp->rx_opt.accecn);
-
-		tcp_accecn_saw_opt_fail_recv(tp, saw_opt);
-		tp->accecn_opt_demand = 2;
-	}
-}
