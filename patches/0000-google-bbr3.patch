-				  const struct libeth_xdp_tx_bulk *bq),
-		       bool (*queue)(struct libeth_xdp_tx_bulk *bq,
-				     struct libeth_xdp_buff *xdp,
-				     bool (*flush_bulk)
-					  (struct libeth_xdp_tx_bulk *bq,
-					   u32 flags)),
-		       bool (*flush_bulk)(struct libeth_xdp_tx_bulk *bq,
-					  u32 flags))
-{
-	u32 act;
-
